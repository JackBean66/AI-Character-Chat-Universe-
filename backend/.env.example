# ====== 数据库配置 ======
# 数据库主机地址（本地开发使用 localhost，部署时平台会提供）
DB_HOST=localhost
DB_PORT=3306

# 数据库名称
DB_NAME=philosophy_ai

# 数据库用户
DB_USER=aichat_user

# 数据库密码（请使用强密码）
DB_PASSWORD=your_secure_password_here

# ====== Flask 配置 ======
# Flask 密钥（用于 session 和签名，请使用随机字符串）
SECRET_KEY=your_random_secret_key_change_this_in_production

# Flask 环境
FLASK_ENV=development
FLASK_DEBUG=true

# ====== JWT 配置 ======
# JWT 密钥（建议与 SECRET_KEY 不同）
JWT_SECRET=your_jwt_secret_key_here

# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=24

# ====== API 配置 ======
# OpenAI API 配置（可选，用于 AI 对话功能）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 或者使用 DeepSeek API（国内推荐）
# OPENAI_API_BASE=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_deepseek_api_key
# OPENAI_MODEL=deepseek-chat
